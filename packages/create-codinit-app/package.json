  "license": "MIT",
  "homepage": "https://codinit.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/codinit-dev/codinit"
  },
  "bugs": {
    "url": "https://github.com/codinit-dev/codinit/issues"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.12",
    "ora": "^7.0.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
