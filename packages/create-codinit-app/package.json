{
  "name": "create-codinit-app",
  "version": "1.0.0",
  "description": "CLI to bootstrap CodinIT projects with templates and sandbox providers",
  "type": "module",
  "main": "index.js",
  "bin": {
    "create-codinit-app": "./index.js"
  },
  "files": [
